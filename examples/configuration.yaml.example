notifications_manager:

homeassistant:
  packages: !include_dir_named packages

# Optional SMTP transport used by examples/notify_transverse.yaml.
# Keep real server, sender and credentials in secrets.yaml.
notify:
  - name: notify_smtp
    platform: smtp
    server: !secret notify_smtp_server
    port: !secret notify_smtp_port
    timeout: 15
    sender: !secret notify_smtp_sender
    recipient: !secret notify_smtp_recipient_default
    sender_name: "Home Assistant"
    encryption: none
